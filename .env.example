# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit the real file.

# ── OpenAI (plain API) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model to use across the workshop notebooks
# Good defaults: gpt-4o-mini (cheap), gpt-4o (better), gpt-4.1-mini (cheapest capable)
OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI (enterprise alternative — leave blank if using plain OpenAI) ──
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-prod
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── HuggingFace (Part 1 Section 5, Part 2 Task 4) ─────────────────────────────
# Free token from https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_...

# ── Google Custom Search (Part 3) ─────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── EPAM internal model (if/when access is granted) ───────────────────────────
# EPAM_API_KEY=
# EPAM_API_BASE=https://...
